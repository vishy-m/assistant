# Xcode / build
.build/
DerivedData/
# Track project.pbxproj (target/file membership) but ignore everything else in
# the .xcodeproj bundle, so new source files added to the Xcode targets are
# shared across clones rather than living only on one machine.
*.xcodeproj/*
!*.xcodeproj/project.pbxproj
*.xcworkspace
xcuserdata/

# SPM
.swiftpm/
Package.resolved

# macOS
.DS_Store

# Generated launchd plists in user's home (just in case)
*.plist.local

.claude/

/docs/
/Tests/
/taste-skill/
/superpowers/
